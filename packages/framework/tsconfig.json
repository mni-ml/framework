{
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "esnext",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": [
    "src/index.ts",
    "src/nn.ts",
    "src/extensions.ts",
    "src/toy/**/*.ts",
    "src/core/index.ts",
    "src/core/tensor.ts",
    "src/core/autodiff.ts",
    "src/core/operators.ts",
    "src/nn/**/*.ts",
    "src/optimizer.ts",
    "src/datasets.ts",
    "src/scalar.ts",
    "src/scalar_functions.ts",
    "src/tensor_data.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "dist",
    "node_modules"
  ]
}
